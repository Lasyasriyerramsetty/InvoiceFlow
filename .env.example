# Application
APP_NAME="AP Invoice & Contract Exception Agent"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://ap_user:ap_secure_password@localhost:5432/ap_invoice_db
DATABASE_SYNC_URL=postgresql://ap_user:ap_secure_password@localhost:5432/ap_invoice_db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT & OAuth
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Google Document AI
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ap_minio_admin
MINIO_SECRET_KEY=ap_minio_secure_password
MINIO_BUCKET=ap-documents
MINIO_SECURE=false

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=ap_knowledge_base

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
